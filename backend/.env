PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=hypernova_crm

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=8h

# CORS - Lovable frontend origin
CORS_ORIGIN=http://localhost:8080

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
